{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "npm",
			"script": "build",
			"group": "build",
			"problemMatcher": "$tsc"
		},
		{
			"label": "serve",
			"type": "shell",
			"command": "python3",
			"args": ["-m", "http.server", "4173", "--bind", "127.0.0.1"],
			"isBackground": true,
			"runOptions": {
				"runOn": "folderOpen",
				"instanceLimit": 1
			},
			"problemMatcher": {
				"owner": "custom",
				"pattern": {
					"regexp": ".*"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Serving HTTP on 127\\.0\\.0\\.1 port 4173.*"
				}
			}
		},
		{
			"label": "debug:reload-chrome",
			"type": "shell",
			"command": "osascript",
			"args": [
				"${workspaceFolder}/.vscode/reload-chrome.applescript",
				"http://127.0.0.1:4173"
			],
			"problemMatcher": []
		},
		{
			"label": "debug:prepare-chrome",
			"dependsOrder": "sequence",
			"dependsOn": ["build", "debug:reload-chrome"]
		}
	]
}
