{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"rootDir": "./src",
		"outDir": "./dist",
		"lib": ["DOM", "ES2022"],
		"strict": true,
		"sourceMap": true,
		"inlineSources": true,
		"skipLibCheck": true,
		"noEmitOnError": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts"],
	"exclude": ["dist"]
}
